{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rtlx.invalid/schemas/diagnostic.schema.json",
  "title": "RTLX Diagnostic v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "code",
    "severity",
    "requirementId",
    "scope",
    "timestamp",
    "details"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "code": { "type": "string", "pattern": "^RTLX-[A-Z]+-[0-9]{3}$" },
    "severity": { "enum": ["info", "warning", "error", "fatal"] },
    "requirementId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "scope": { "enum": ["feature", "candidate", "frame", "site", "extension"] },
    "timestamp": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T" },
    "details": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean", "null"] },
      "propertyNames": {
        "not": {
          "pattern": "[Tt][Ee][Xx][Tt]|[Uu][Rr][Ll]|[Ss][Ee][Ll][Ee][Cc][Tt][Oo][Rr]|[Hh][Tt][Mm][Ll]|[Ff][Oo][Rr][Mm]|[Cc][Ll][Ii][Pp][Bb][Oo][Aa][Rr][Dd]|[Qq][Uu][Ee][Rr][Yy]|[Ff][Rr][Aa][Gg][Mm][Ee][Nn][Tt]"
        }
      }
    }
  },
  "x-registry": {
    "version": 1,
    "changelog": ["1.0.0 initial diagnostic contract"],
    "forwardCompatibility": "Unknown diagnostic codes are preserved if shape and privacy constraints pass."
  }
}
